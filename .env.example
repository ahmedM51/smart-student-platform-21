# Server / Vercel Environment Variables
# Do NOT commit real secrets. Put real values in Vercel Project Settings -> Environment Variables.

# Gemini API Key (required for AI features)
GEMINI_API_KEY=
# Alternative name supported by the code
API_KEY=

# MongoDB (only needed if you use server.js or any Mongo-based APIs)
MONGODB_URI=

# Supabase (frontend uses anon key; still keep it in env if you want)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
